---
<section id="home">
  <div class="hero-grid">
    <div class="hero-content">
      <p class="hero-eyebrow">// Software Engineer & Web Developer</p>
      <h1 class="hero-name">
        Hola, soy<br>
        <span>Matias Azcurra</span>
      </h1>
      <p class="hero-tagline">
        Desarrollo software web y soluciones a medida. Me especializo en Python, desarrollo web y automatización — construyo cosas que funcionan.
      </p>
      <div class="hero-cta">
        <a href="#projects" class="btn-primary">Ver proyectos</a>
        <a href="#contact" class="btn-outline">Contactarme</a>
      </div>
    </div>

    <div class="hero-visual">
      <div class="code-card">
        <div class="code-bar">
          <div class="code-dot dot-r"></div>
          <div class="code-dot dot-y"></div>
          <div class="code-dot dot-g"></div>
        </div>
        <div class="code-line"><span class="cl-num">1</span><span class="cl-kw">def</span> <span class="cl-fn">developer</span><span class="cl-var">():</span></div>
        <div class="code-line"><span class="cl-num">2</span>&nbsp;&nbsp;<span class="cl-var">name</span> <span class="cl-var">=</span> <span class="cl-str">"Matias Azcurra"</span></div>
        <div class="code-line"><span class="cl-num">3</span>&nbsp;&nbsp;<span class="cl-var">skills</span> <span class="cl-var">=</span> <span class="cl-var">[</span></div>
        <div class="code-line"><span class="cl-num">4</span>&nbsp;&nbsp;&nbsp;&nbsp;<span class="cl-str">"Python"</span><span class="cl-var">,</span> <span class="cl-str">"JavaScript"</span><span class="cl-var">,</span></div>
        <div class="code-line"><span class="cl-num">5</span>&nbsp;&nbsp;&nbsp;&nbsp;<span class="cl-str">"Web Dev"</span><span class="cl-var">,</span> <span class="cl-str">"Soft Dev"</span></div>
        <div class="code-line"><span class="cl-num">6</span>&nbsp;&nbsp;<span class="cl-var">]</span></div>
        <div class="code-line"><span class="cl-num">7</span>&nbsp;&nbsp;<span class="cl-kw">return</span> <span class="cl-fn">build</span><span class="cl-var">(</span><span class="cl-acc">solutions</span><span class="cl-var">)</span></div>
        <div class="code-line"><span class="cl-num">8</span>&nbsp;</div>
        <div class="code-line"><span class="cl-num">9</span><span class="cl-fn">developer</span><span class="cl-var">()</span> <span class="cl-muted"># it works ✓</span></div>
      </div>
    </div>
  </div>

  <div class="scroll-line">
    <div class="scroll-dot"></div>
  </div>
</section>
